# Copy this file to .env.docker.local and adjust values for your machine.

NODE_ENV=production
PATH_URL=http://localhost:8000
PORT=8000

# Host ports exposed on your machine
DB_HOST_PORT=5432

# Database configuration inside Docker network
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=hris_user
DB_PASSWORD=change_me
DB_NAME=hris_db

# JWT configuration
JWT_SECRET_KEY=change_me

# RabbitMQ credentials
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# CORS configuration
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:4000,http://127.0.0.1:8000,http://localhost:3000,http://localhost:5173,http://localhost:4000,http://localhost:8000

# Timezone
OFFICE_TIMEZONE=Asia/Jakarta